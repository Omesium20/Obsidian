# Dev image for the Express backend.
# Source is bind-mounted from the host (see docker-compose.dev.yaml),
# so this image only needs the dependencies pre-installed.
FROM node:22-slim

WORKDIR /usr/local/app

# Install all deps (including devDeps — we need tsx + nodemon at runtime).
COPY package*.json ./
RUN npm install

EXPOSE 3000

# nodemon supervises tsx and respawns it on .ts changes.
# --legacy-watch enables polling, which is required for file events to be
# detected reliably through Docker bind mounts on Windows / WSL2.
CMD ["npx", "nodemon", \
     "--watch", "node/src", \
     "--ext", "ts,js,json", \
     "--legacy-watch", \
     "--exec", "tsx", "node/src/server.ts"]
